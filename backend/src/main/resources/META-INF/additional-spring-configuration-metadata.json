{
  "properties": [
    {
      "name": "app.jwt.secret",
      "type": "java.lang.String",
      "description": "Secret key used to sign JWT tokens."
    },
    {
      "name": "app.jwt.access-token-expiration-ms",
      "type": "java.lang.Long",
      "description": "Access token lifetime in milliseconds."
    },
    {
      "name": "app.jwt.refresh-token-expiration-ms",
      "type": "java.lang.Long",
      "description": "Refresh token lifetime in milliseconds."
    },
    {
      "name": "app.jwt.issuer",
      "type": "java.lang.String",
      "description": "JWT issuer value."
    },
    {
      "name": "app.cors.allowed-origins",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed origins for CORS requests."
    }
  ]
}